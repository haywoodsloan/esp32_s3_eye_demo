// Template for the project's Wi-Fi credentials.
//
//   1. Copy this file to `wifi_credentials.h` in the same directory.
//   2. Fill in WIFI_SSID and WIFI_PASSWORD with your network's values.
//   3. The real `wifi_credentials.h` is listed in .gitignore so the
//      password never ends up in version control.
//
// The defines are simple C string literals and are consumed by
// src/wifi.cpp -- no other code should #include this file.
#pragma once

#define WIFI_SSID      "your-ssid-here"
#define WIFI_PASSWORD  "your-password-here"
