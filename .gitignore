# ESP-IDF build output
build/

# Generated config (the tracked source of truth is sdkconfig.defaults).
# sdkconfig.esp32-s3-devkitc-1 was the old PlatformIO-named variant.
sdkconfig
sdkconfig.old
sdkconfig.esp32-s3-devkitc-1

# Stale PlatformIO artifacts, ignored so an in-place switch from
# PlatformIO doesn't re-commit them.
.pio

# Machine-local VS Code caches + extension-generated IntelliSense config.
# settings.json / extensions.json stay tracked.
.vscode/.browse.c_cpp.db*
.vscode/c_cpp_properties.json
.vscode/launch.json
.vscode/ipch

# IDF Component Manager fetches these on first build from
# dependencies.lock + idf_component.yml. Reproducible, large (~50 MB),
# don't belong in the repo.
managed_components/

# Local point-in-time backups
snapshots/

# Real Wi-Fi credentials live in src/wifi_credentials.h (gitignored).
# A tracked template at src/wifi_credentials.h.example documents the
# expected macros -- copy it and fill in your network's values.
src/wifi_credentials.h

# src/wifi_credentials.h is INTENTIONALLY tracked (with placeholder
# values) so a fresh clone builds out of the box. Run
#   git update-index --skip-worktree src/wifi_credentials.h
# once per clone to keep your local credentials out of commits. See
# the comment at the top of that file for details.

# Auto-generated by scripts/embed_web_html.py
src/web/index_html_data.h
